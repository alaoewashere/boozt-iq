# Copy to .env.local and fill in real values (never commit .env.local).
# ─── Supabase (Postgres + Auth + Storage — primary database) ──────────────────
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Publishable anon key (safe for browser — used by the browser/SSR clients)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_publishable_key
# Service role — server only, never NEXT_PUBLIC_. Used by Next.js API routes & import scripts.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# Cloudinary (product images — admin upload)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# App config
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Comma-separated list of admin emails. Any user with one of these emails
# (signed in via Supabase Auth) is treated as admin. Also used by `npm run setup-admin`.
ADMIN_EMAIL=
# Optional: when running `npm run setup-admin` for the first time. If omitted,
# a random password is generated and printed.
# ADMIN_PASSWORD=

NEXT_PUBLIC_WHATSAPP_NUMBER=

# Groq — server-only (chat widget, order tracking AI, caption generation)
GROQ_API_KEY=your_groq_api_key

# Optional: one-shot import of products.csv + all Boozt new *.csv with images
# (wipes the products table — see lib/import-full-catalog.ts)
# npm run import:full-catalog:fresh
