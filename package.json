    "react-dom": "^19.0.0",
    "react-hook-form": "^7.55.0",
    "server-only": "^0.0.1",
    "tailwindcss-rtl": "^0.9.0",
    "three": "^0.184.0",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
