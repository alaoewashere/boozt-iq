  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "tsx --env-file=.env.local lib/seed.ts",
    "setup-admin": "tsx --env-file=.env.local lib/setup-admin.ts",
    "import:products-csv": "tsx --env-file=.env.local lib/import-products-from-products-csv.ts products.csv --upsert --images-dir=images --public-images",
    "import:products-only": "tsx --env-file=.env.local lib/reset-products-to-products-csv.ts",
    "import:boozt6": "tsx --env-file=.env.local lib/import-products-from-boozt6-csv.ts \"Boozt new 6.csv\"",
    "import:full-catalog": "tsx --env-file=.env.local lib/import-full-catalog.ts --public-images",
    "import:full-catalog:fresh": "tsx --env-file=.env.local lib/import-full-catalog.ts --public-images --replace-all"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.86.1",
