    "framer-motion": "^12.4.7",
    "groq-sdk": "^1.1.2",
    "lucide-react": "^0.487.0",
    "next": "15.5.14",
    "next-intl": "^4.9.0",
    "next-themes": "^0.4.6",
    "pdfmake": "^0.3.7",
